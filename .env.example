# BlitzVault — environment setup index (no secrets in this file)
#
# Copy per-app examples and fill in Clerk keys from https://dashboard.clerk.com
#
#   cp backend/.env.example backend/.env.local
#   cp frontend/.env.example frontend/.env.local
#
# Real values belong only in *.env.local (gitignored).

# --- Database (matches docker-compose.dev.yml) ---
# Set these in backend/.env.local:
#   DB_HOST=127.0.0.1
#   DB_PORT=5432
#   DB_USERNAME=postgres
#   DB_PASSWORD=postgres
#   DB_DATABASE=drive_clone

# --- API (Monday contract) ---
# Backend PORT (backend/.env.local): 5001
# Frontend NEXT_PUBLIC_BACKEND_URL (frontend/.env.local): http://localhost:5001
# API path prefix: /api/v1

# --- Clerk (required in both backend and frontend .env.local) ---
# CLERK_SECRET_KEY=sk_test_...
# CLERK_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...  (frontend)
# CLERK_JWT_ISSUER=https://<instance>.clerk.accounts.dev  (backend)

# See docs/contracts-week1-monday.md and docs/sprint-week-1.md
