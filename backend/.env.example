# Required — server exits at boot if missing
NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=drive_clone
PORT=5001

CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev

# Optional
CLERK_JWT_AUDIENCE=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
AUTH_BEARER_TOKEN=

# Deprecated Google OAuth backend flow (optional; routes removed in Phase 0)
CLERK_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback
CLERK_GOOGLE_CALLBACK_URL=http://localhost:5001/api/v1/auth/signin/google/callback
