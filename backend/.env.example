# Required — server exits at boot if missing
# DB defaults match docker-compose.dev.yml
NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=blitz_vault
PORT=5001

CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev

# Optional
CLERK_JWT_AUDIENCE=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis (defaults match docker-compose.dev.yml; used by BullMQ workers + rate limit)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Object storage — Cloudinary now (creds from https://cloudinary.com console)
STORAGE_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Future drivers (set STORAGE_DRIVER=s3|r2, add these — not implemented yet):
# STORAGE_ENDPOINT=
# STORAGE_REGION=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_FORCE_PATH_STYLE=true
