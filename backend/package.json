{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "type": "commonjs",
  "main": "server.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node server.ts",
    "worker:dev": "ts-node src/workers/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/db.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/db.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/config/db.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/db.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/backend": "^3.2.13",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@swc/core": "^1.15.41",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.39.0",
    "globals": "^16.5.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "typescript": "^5",
    "typescript-eslint": "^8.46.4",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
